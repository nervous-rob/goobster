# Discord Configuration (required)
DISCORD_CLIENT_ID=your_client_id
DISCORD_BOT_TOKEN=your_bot_token
DISCORD_GUILD_IDS=["guild_id_1","guild_id_2"]

# AI providers (all optional - the bot falls back to a local Ollama server)
OPENAI_API_KEY=your_openai_key
GEMINI_API_KEY=your_google_key
AI_PROVIDER=openai            # openai | gemini | ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b

# AI models (optional - sensible defaults are applied)
OPENAI_CHAT_MODEL=gpt-5.4-mini        # default everyday chat model
OPENAI_THOUGHTFUL_MODEL=gpt-5.5       # used by /thoughtfulmode
OPENAI_IMAGE_MODEL=gpt-image-2        # image generation
OPENAI_EMBEDDING_MODEL=text-embedding-3-small   # long-term memory embeddings
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe  # /voicechat speech-to-text
GEMINI_MODEL=gemini-3.5-flash
PERPLEXITY_MODEL=sonar-pro
OLLAMA_EMBEDDING_MODEL=nomic-embed-text  # memory embeddings when self-hosted

# Long-term memory (optional)
MEMORY_ENABLED=true
MEMORY_MAX_ENTRIES=5000               # per-guild cap
MEMORY_RECALL_LIMIT=5                 # memories injected per message
MEMORY_MIN_SIMILARITY=0.3             # cosine similarity threshold

# Optional integrations
PERPLEXITY_API_KEY=your_perplexity_key
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Rachel (default)

# Runtime (optional)
GOOBSTER_DB_PATH=./data/goobster.sqlite
GOOBSTER_LOG_DIR=./logs
FFMPEG_PATH=ffmpeg
LOG_LEVEL=info

# Bot Configuration
DEFAULT_PROMPT=your_default_prompt

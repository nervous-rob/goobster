# Discord Configuration (required)
DISCORD_CLIENT_ID=your_client_id
DISCORD_BOT_TOKEN=your_bot_token
DISCORD_GUILD_IDS=["guild_id_1","guild_id_2"]

# AI providers (all optional - the bot falls back to a local Ollama server)
OPENAI_API_KEY=your_openai_key
GEMINI_API_KEY=your_google_key
AI_PROVIDER=openai            # openai | gemini | ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b

# Optional integrations
PERPLEXITY_API_KEY=your_perplexity_key
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Rachel (default)

# Runtime (optional)
GOOBSTER_DB_PATH=./data/goobster.sqlite
GOOBSTER_LOG_DIR=./logs
FFMPEG_PATH=ffmpeg
LOG_LEVEL=info

# Bot Configuration
DEFAULT_PROMPT=your_default_prompt

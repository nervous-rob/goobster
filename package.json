{
  "name": "goobster",
  "version": "1.0.0",
  "description": "Discord bot with adventure capabilities",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "deploy-commands": "node deploy-commands.js",
    "start": "npm run deploy-commands && node index.js",
    "dev": "nodemon index.js",
    "db-init": "node initDb.js",
    "lint": "eslint . --max-warnings 60",
    "smoke": "node scripts/smoke-require.js",
    "test:integration": "jest --config jest.integration.config.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@discord/embedded-app-sdk": "^2.5.0",
    "@discordjs/builders": "^1.7.0",
    "@discordjs/rest": "^2.2.0",
    "@discordjs/voice": "^0.19.2",
    "@snazzah/davey": "^0.1.12",
    "axios": "^1.7.9",
    "better-sqlite3": "^11.8.1",
    "concurrently": "^8.0.0",
    "cors": "^2.8.5",
    "cron-parser": "^5.0.4",
    "discord.js": "^14.26.4",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "libsodium-wrappers": "^0.7.15",
    "mime": "^3.0.0",
    "node-fetch": "^2.7.0",
    "nodemon": "^3.0.0",
    "openai": "^6.45.0",
    "opusscript": "^0.0.8",
    "play-dl": "^1.9.7",
    "prism-media": "^1.3.5",
    "sharp": "^0.32.6",
    "sodium-native": "^4.0.4",
    "sqlite-vec": "^0.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/mssql": "^9.1.4",
    "@types/node": "^22.10.5",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "mock-socket": "^9.3.1",
    "prettier": "^3.2.5",
    "ts-jest": "^29.4.11"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "globalSetup": "<rootDir>/tests/setup/globalSetup.js",
    "globalTeardown": "<rootDir>/tests/setup/globalTeardown.js",
    "collectCoverageFrom": [
      "utils/**/*.{js,ts}",
      "commands/**/*.{js,ts}",
      "!**/node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "@discordjs/node-pre-gyp": "npm:@mapbox/node-pre-gyp@^2.0.3",
    "glob": "^13.0.6"
  }
}
